# Secrets — NEVER commit
.env
.env.local
.env.production
*.key
*.pem
*.p12
*.pfx
*credentials*
**/secrets/

# Rust
target/
**/*.rs.bk
*.pdb

# Cargo. We track .cargo/audit.toml (config — small, source-of-truth for
# cargo-audit ignores); everything else under .cargo/ is build/install
# state and stays ignored.
.cargo/*
!.cargo/audit.toml
.cargo-bin/

# Sccache
.sccache/

# Node / pnpm. (Generic `dist/` removed — the only `dist/` we have is
# frontend/dist/, handled explicitly further down so the .gitkeep stays
# tracked. Other tools' build outputs would appear in tool-specific
# subdirectories already covered.)
node_modules/
.pnpm-store/
.vite/

# TypeScript
*.tsbuildinfo

# Frontend build output (embedded in the binary at build time by rust-embed).
# crates/viewer/build.rs creates this directory on fresh checkouts so the
# compile-time scan doesn't fail before `pnpm build` has run.
frontend/dist/

# Mise
.mise/
.tool-versions.bak

# Snapshots
.snapshots/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
logs/
.logs/

# Agent session state (Claude Code)
.remember/

# init.sh state file
.init-state

# Coverage
coverage/
*.lcov
*.profraw
*.profdata

# CI artifacts
artifacts/

# IMPORTANT: Always commit:
# - All lockfiles (Cargo.lock, pnpm-lock.yaml, package-lock.json)
# - All ADRs and decision documents
# - SECURITY.md, PORTABILITY.md, BLOCKED.md, STATUS.md
