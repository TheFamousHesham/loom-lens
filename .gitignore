# Secrets — NEVER commit
.env
.env.local
.env.production
*.key
*.pem
*.p12
*.pfx
*credentials*
**/secrets/

# Rust
target/
**/*.rs.bk
*.pdb

# Cargo
.cargo/
.cargo-bin/

# Sccache
.sccache/

# Node / pnpm. (Generic `dist/` removed — the only `dist/` we have is
# frontend/dist/, handled explicitly further down so the .gitkeep stays
# tracked. Other tools' build outputs would appear in tool-specific
# subdirectories already covered.)
node_modules/
.pnpm-store/
.vite/

# TypeScript
*.tsbuildinfo

# Frontend build output (will be embedded in binary at build time).
# Keep the directory tracked via .gitkeep so rust-embed compiles on a
# fresh checkout; the actual build artifacts stay ignored.
frontend/dist/*
!frontend/dist/.gitkeep

# Mise
.mise/
.tool-versions.bak

# Snapshots
.snapshots/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
logs/
.logs/

# Agent session state (Claude Code)
.remember/

# init.sh state file
.init-state

# Coverage
coverage/
*.lcov
*.profraw
*.profdata

# CI artifacts
artifacts/

# IMPORTANT: Always commit:
# - All lockfiles (Cargo.lock, pnpm-lock.yaml, package-lock.json)
# - All ADRs and decision documents
# - SECURITY.md, PORTABILITY.md, BLOCKED.md, STATUS.md
