# Loom Lens environment configuration
# Copy to .env and fill in. NEVER COMMIT .env.
# Permissions: chmod 600 .env

# ============================================================================
# REQUIRED
# ============================================================================

# Anthropic API key for Claude Code agent.
# Provision with a HARD SPEND CAP set in the Anthropic console.
# Project-scoped key; do not reuse across projects.
ANTHROPIC_API_KEY=

# GitHub deploy key for this repo. Scoped to ONE repository.
# Path to the private key file (which lives outside the project tree).
GITHUB_DEPLOY_KEY_PATH=/home/loom/.ssh/loom_lens_deploy
GITHUB_REPO=git@github.com:TheFamousHesham/loom-lens.git

# Git author identity for commits made by the agent.
GIT_AUTHOR_NAME="Hesham Mashhour"
GIT_AUTHOR_EMAIL="hesham@betterbrainlab.com"
GIT_COMMITTER_NAME="Hesham Mashhour"
GIT_COMMITTER_EMAIL="hesham@betterbrainlab.com"

# ============================================================================
# OPTIONAL
# ============================================================================

# Backup target. Used by scripts/snapshot.sh.
BACKUP_TARGET_HOST=
BACKUP_TARGET_PATH=/srv/loom-lens-backups
BACKUP_SSH_KEY=/home/loom/.ssh/loom_backup

# Token spend alert webhook (Discord/Slack/etc.).
SPEND_ALERT_WEBHOOK=

# ============================================================================
# REGISTRY PUBLISHING — DO NOT SET WITHOUT EXPLICIT REVIEW
# ============================================================================
#
# These are NOT used during normal development. They are referenced by
# the release workflow (.github/workflows/release.yml) which requires
# manual dispatch. The agent NEVER reads these.
#
# NPM_TOKEN should live as a GitHub repo secret, not in this file.
# CRATES_IO_TOKEN should live as a GitHub repo secret, not in this file.

# ============================================================================
# DERIVED — DO NOT EDIT
# ============================================================================

LOOM_LENS_ROOT=/opt/loom-lens
