#!/usr/sbin/nft -f
#
# Egress allowlist for the Loom project VPS.
# Apply with: sudo nft -f /etc/nftables.d/loom-egress.nft
# Make persistent on Debian/Ubuntu: include this file from /etc/nftables.conf
#
# This is the strongest single defense against the agent being prompt-injected
# into exfiltrating data. Even if the agent's process tries to POST credentials
# to attacker.com, the connection won't open because the IP isn't in the
# resolved allowlist set.
#
# IMPORTANT: This file uses a hostname-resolution helper script. The
# `loom_allowed_ips` set is populated from the hostname list below by
# scripts/refresh-egress.sh, which runs hourly via cron. nftables itself
# can't resolve hostnames at apply-time, so we maintain the IP set out-of-band.
#
# Allowed destinations (the only domains the agent may reach):
#   Package registries:
#     - crates.io, static.crates.io, index.crates.io
#     - registry.npmjs.org, registry.yarnpkg.com
#     - pypi.org, files.pythonhosted.org
#     - proxy.golang.org, sum.golang.org
#     - hackage.haskell.org, downloads.haskell.org
#   Code & API:
#     - github.com, api.github.com, codeload.github.com
#     - objects.githubusercontent.com, raw.githubusercontent.com
#     - api.anthropic.com
#     - hub.docker.com, registry-1.docker.io, auth.docker.io
#     - production.cloudflare.docker.com
#   System:
#     - archive.ubuntu.com, security.ubuntu.com (apt)
#     - deb.debian.org (apt)
#     - 1.1.1.1, 9.9.9.9 (DNS)
#     - $BACKUP_TARGET_HOST (rsync over SSH)

table inet loom_filter {

    # IP allowlist set, populated by scripts/refresh-egress.sh.
    set loom_allowed_ips_v4 {
        type ipv4_addr
        flags interval
        auto-merge
    }

    set loom_allowed_ips_v6 {
        type ipv6_addr
        flags interval
        auto-merge
    }

    # Loopback always allowed.
    chain output {
        type filter hook output priority 0; policy drop;

        # Connection state: allow established/related.
        ct state established,related accept

        # Loopback.
        oifname "lo" accept

        # DNS to allowed resolvers only (Cloudflare, Quad9).
        ip daddr { 1.1.1.1, 1.0.0.1, 9.9.9.9 } udp dport 53 accept
        ip daddr { 1.1.1.1, 1.0.0.1, 9.9.9.9 } tcp dport 53 accept
        ip6 daddr { 2606:4700:4700::1111, 2620:fe::fe } udp dport 53 accept
        ip6 daddr { 2606:4700:4700::1111, 2620:fe::fe } tcp dport 53 accept

        # NTP for time sync.
        udp dport 123 ip daddr { 0.pool.ntp.org, 1.pool.ntp.org } accept

        # ICMP for path MTU discovery and basic connectivity.
        ip protocol icmp icmp type { destination-unreachable, time-exceeded, echo-request, echo-reply } accept
        ip6 nexthdr icmpv6 icmpv6 type { destination-unreachable, packet-too-big, time-exceeded, echo-request, echo-reply } accept

        # Allowlist set: HTTPS to allowed IPs.
        ip daddr @loom_allowed_ips_v4 tcp dport { 443, 80 } accept
        ip6 daddr @loom_allowed_ips_v6 tcp dport { 443, 80 } accept

        # SSH to backup target (port may be non-standard; adjust if your backup uses another).
        # Refresh script also adds backup target to the allowlist sets.
        ip daddr @loom_allowed_ips_v4 tcp dport 22 accept
        ip6 daddr @loom_allowed_ips_v6 tcp dport 22 accept

        # Log everything else at a low rate, then drop.
        limit rate 10/minute log prefix "loom-egress-drop: " level info
        counter drop
    }

    # Inbound: SSH only, expected to be on Tailscale anyway.
    chain input {
        type filter hook input priority 0; policy drop;

        ct state established,related accept
        iifname "lo" accept

        # SSH (adjust port if non-standard). Best behind Tailscale.
        tcp dport 22 ct state new accept

        # ICMP basic.
        ip protocol icmp icmp type { destination-unreachable, time-exceeded, echo-request, echo-reply } accept
        ip6 nexthdr icmpv6 icmpv6 type { destination-unreachable, packet-too-big, time-exceeded, echo-request, echo-reply, neighbor-solicitation, neighbor-advertisement, router-advertisement } accept

        limit rate 10/minute log prefix "loom-input-drop: " level info
        counter drop
    }

    chain forward {
        type filter hook forward priority 0; policy drop;
    }
}
